# Airflow Configuration
AIRFLOW_IMAGE_NAME=your-image-name:latest
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=/opt/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW_ADMIN_USER=your-admin-username
AIRFLOW_ADMIN_PASSWORD=your-admin-password

# Database Connections
MYSQL_STAGING_HOST=staging-mysql
MYSQL_STAGING_PORT=3306
MYSQL_STAGING_DATABASE=your-mysql-database
MYSQL_STAGING_USER=your-mysql-user
MYSQL_STAGING_PASSWORD=your-mysql-password

POSTGRES_WAREHOUSE_HOST=warehouse
POSTGRES_WAREHOUSE_PORT=5432
POSTGRES_WAREHOUSE_DATABASE=your-postgres-database
POSTGRES_WAREHOUSE_USER=your-postgres-user
POSTGRES_WAREHOUSE_PASSWORD=your-postgres-password

# Project Paths (resolved inside the container via volume mounts)
DATA_DIR=/opt/airflow/data
JARS_DIR=/opt/airflow/jars
SQL_DIR=/opt/airflow/sql

# Spark JARs
SPARK_JARS=/opt/airflow/jars/mysql-connector-j-9.6.0.jar,/opt/airflow/jars/postgresql-42.7.9.jar

# Airflow Connections (auto-registered on startup)
AIRFLOW_CONN_MYSQL_STAGING=mysql://your-mysql-user:your-mysql-password@staging-mysql:3306/your-mysql-database
AIRFLOW_CONN_POSTGRES_WAREHOUSE=postgresql://your-postgres-user:your-postgres-password@warehouse:5432/your-postgres-database
AIRFLOW_CONN_SPARK_DEFAULT=spark://local
