# Airflow Configuration
AIRFLOW_IMAGE_NAME=globalsportsfootwearproject-airflow-apiserver:latest
AIRFLOW_UID=50000
AIRFLOW_PROJ_DIR=/opt/airflow
AIRFLOW__CORE__FERNET_KEY=c-wRQIBbduVY-j0lQru2s3reEOJFcNqrwTPIm6LXAkM=
AIRFLOW_ADMIN_USER=airflow
AIRFLOW_ADMIN_PASSWORD=airflow

# Database Connections
MYSQL_STAGING_HOST=mysql
MYSQL_STAGING_PORT=3306
MYSQL_STAGING_DATABASE=sales_staging
MYSQL_STAGING_USER=staging_user
MYSQL_STAGING_PASSWORD=password123

POSTGRES_WAREHOUSE_HOST=warehouse
POSTGRES_WAREHOUSE_PORT=5432
POSTGRES_WAREHOUSE_DATABASE=sales_warehouse
POSTGRES_WAREHOUSE_USER=postgres
POSTGRES_WAREHOUSE_PASSWORD=password123

# Project Paths (resolved inside the container via volume mounts)
DATA_DIR=/opt/airflow/data
JARS_DIR=/opt/airflow/jars
SQL_DIR=/opt/airflow/sql

# Spark JARs
SPARK_JARS=/opt/airflow/jars/mysql-connector-j-9.6.0.jar,/opt/airflow/jars/postgresql-42.7.9.jar

# Airflow Connections (auto-registered on startup)
AIRFLOW_CONN_MYSQL_STAGING=mysql://staging_user:password123@staging-mysql:3306/sales_staging
AIRFLOW_CONN_POSTGRES_WAREHOUSE=postgresql://postgres:password123@warehouse:5432/sales_warehouse
AIRFLOW_CONN_SPARK_DEFAULT=spark://local